<!DOCTYPE html><html><head><meta charset="utf-8"><style>@page{margin:0}*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Segoe UI','Helvetica Neue',Arial,sans-serif;font-size:10pt;color:#1a1a2e;line-height:1.6;background:#fff}.cover{page-break-after:always;height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;background:linear-gradient(135deg,#0B1120 0%,#1F2937 100%);color:#fff;text-align:center;padding:2in}.cover .brand{font-size:14pt;letter-spacing:4px;color:#F59E0B;text-transform:uppercase;margin-bottom:12px}.cover h1{font-size:32pt;font-weight:700;color:#F9FAFB;margin-bottom:8px}.cover .subtitle{font-size:16pt;color:#9CA3AF;margin-bottom:32px}.cover .meta{font-size:10pt;color:#6B7280;line-height:2}.cover .score-badge{display:inline-block;margin-top:24px;padding:12px 32px;border-radius:8px;background:#FEE2E2;color:#EF4444;font-size:14pt;font-weight:700}h2{font-size:16pt;color:#0B1120;border-bottom:3px solid #F59E0B;padding-bottom:6px;margin:32px 0 16px;page-break-after:avoid}h3{font-size:12pt;color:#374151;margin:20px 0 10px;page-break-after:avoid}p{margin-bottom:10px;text-align:justify}.narrative{font-size:10pt;color:#374151;margin:8px 0 16px;line-height:1.7}.kpi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:14px 0}.kpi-grid.four{grid-template-columns:repeat(4,1fr)}.kpi{background:#F9FAFB;border:1px solid #E5E7EB;border-radius:6px;padding:14px 10px;text-align:center}.kpi .value{font-size:20pt;font-weight:700;color:#0B1120}.kpi .value.accent{color:#F59E0B}.kpi .value.green{color:#10B981}.kpi .value.blue{color:#3B82F6}.kpi .value.red{color:#EF4444}.kpi .label{font-size:7.5pt;color:#6B7280;text-transform:uppercase;letter-spacing:0.5px;margin-top:4px}table{width:100%;border-collapse:collapse;margin:10px 0 18px;font-size:9pt}th{background:#1F2937;color:#fff;padding:7px 10px;text-align:left;font-weight:600;font-size:8.5pt}td{padding:6px 10px;border-bottom:1px solid #E5E7EB;vertical-align:top}tr:nth-child(even) td{background:#F9FAFB}.text-right{text-align:right}.text-center{text-align:center}.bold{font-weight:700}.highlight-row td{background:#F0FDF4!important;font-weight:700}.scope-tag{display:inline-block;background:#EEF2FF;color:#4338CA;padding:2px 8px;font-size:7.5pt;border-radius:4px;margin-left:8px;font-weight:600}.bar-chart{margin:12px 0}.bar-row{display:flex;align-items:center;margin-bottom:6px}.bar-label{width:140px;font-size:8.5pt;color:#374151;text-align:right;padding-right:10px;flex-shrink:0}.bar-track{flex:1;height:20px;background:#F3F4F6;border-radius:3px;overflow:hidden}.bar-fill{height:100%;border-radius:3px;display:flex;align-items:center;padding-left:8px;font-size:7.5pt;color:#fff;font-weight:600}.swot-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:14px 0}.swot-box{border:1px solid #E5E7EB;border-radius:6px;padding:14px;page-break-inside:avoid}.swot-box h3{margin-top:0;font-size:11pt}.swot-box ul{padding-left:18px;margin-top:6px}.swot-box li{margin-bottom:5px;font-size:9pt;line-height:1.5}.s-box{border-left:4px solid #10B981}.s-box h3{color:#10B981}.w-box{border-left:4px solid #EF4444}.w-box h3{color:#EF4444}.o-box{border-left:4px solid #3B82F6}.o-box h3{color:#3B82F6}.t-box{border-left:4px solid #F97316}.t-box h3{color:#F97316}.score-big{text-align:center;margin:20px 0}.score-big .number{font-size:48pt;font-weight:700;color:#F59E0B}.score-big .out-of{font-size:14pt;color:#9CA3AF}.score-big .rec{font-size:16pt;font-weight:700;padding:8px 24px;border-radius:6px;display:inline-block;margin-top:8px}.page-break{page-break-before:always}.disclaimer{margin-top:32px;padding:16px;background:#F9FAFB;border:1px solid #E5E7EB;border-radius:6px;font-size:8pt;color:#6B7280;line-height:1.6}.source-list{font-size:8pt;color:#6B7280}.source-list td{padding:3px 8px;font-size:8pt}.toc{margin:20px 0}.toc-item{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px dotted #D1D5DB;font-size:11pt}.toc-item .title{color:#1a1a2e}.section-num{color:#F59E0B;font-weight:700;margin-right:8px}.def-list{display:grid;grid-template-columns:180px 1fr;gap:6px 16px;margin:12px 0}.def-list dt{font-weight:600;color:#6B7280;font-size:9pt}.def-list dd{font-size:9pt;color:#1a1a2e}.prov-chip{display:inline-block;margin-left:6px;padding:1px 6px;border-radius:9px;font-size:6.5pt;font-weight:700;letter-spacing:0.3px;vertical-align:middle;line-height:1.3}.prov-chip.prov-dot{padding:0 4px;font-size:10pt;line-height:1}.prov-measured{background:#DCFCE7;color:#166534;border:1px solid #86EFAC}.prov-derived{background:#DBEAFE;color:#1E40AF;border:1px solid #93C5FD}.prov-modeled{background:#FEF3C7;color:#92400E;border:1px solid #FCD34D}.prov-llm{background:#F3E8FF;color:#6B21A8;border:1px solid #D8B4FE}.prov-missing{background:#F3F4F6;color:#6B7280;border:1px solid #D1D5DB}.prov-error{background:#FEE2E2;color:#991B1B;border:1px solid #FCA5A5}.prov-error-block{margin:10px 0;padding:10px 12px;border:1px dashed #FCA5A5;background:#FEF2F2;border-radius:6px}.prov-error-head{font-weight:700;color:#991B1B;font-size:10pt}.prov-error-body{color:#7F1D1D;font-size:9pt;margin-top:4px}</style></head><body><div class="cover"><div class="brand">Infinity Markets</div><h1>New Construction Market Study</h1><div class="subtitle">Incomplete PA</div><div class="meta">April 22, 2026<br>Prepared for Forbes Capretto Homes<br>Land Acquisition &amp; Strategic Planning</div><div class="score-badge">PASS — Score: 0.0/10</div></div><h2 style="border:none;margin-top:0;">Table of Contents</h2><div class="toc"><div class="toc-item"><span class="title"><span class="section-num">1.</span>Executive Summary</span></div><div class="toc-item"><span class="title"><span class="section-num">2.</span>Market Area</span></div><div class="toc-item"><span class="title"><span class="section-num">3.</span>Demographics</span></div><div class="toc-item"><span class="title"><span class="section-num">4.</span>Housing Market</span></div><div class="toc-item"><span class="title"><span class="section-num">5.</span>Building Permits</span></div><div class="toc-item"><span class="title"><span class="section-num">6.</span>Competitive Landscape</span></div><div class="toc-item"><span class="title"><span class="section-num">7.</span>Absorption & Demand</span></div><div class="toc-item"><span class="title"><span class="section-num">8.</span>Pricing Strategy</span></div><div class="toc-item"><span class="title"><span class="section-num">9.</span>Land Economics</span></div><div class="toc-item"><span class="title"><span class="section-num">10.</span>Proforma Scenarios</span></div><div class="toc-item"><span class="title"><span class="section-num">11.</span>Regulatory Environment</span></div><div class="toc-item"><span class="title"><span class="section-num">12.</span>Market Scorecard</span></div><div class="toc-item"><span class="title"><span class="section-num">13.</span>SWOT Analysis</span></div><div class="toc-item"><span class="title"><span class="section-num">14.</span>Data Sources & Methodology</span></div></div><h2 class="page-break"><span class="section-num">1.</span> Executive Summary</h2><div class="score-big"><div class="number">0.0</div><div class="out-of">out of 10.0</div><div class="rec" style="background:#FEE2E2;color:#EF4444;">PASS</div></div><p class="narrative">This institutional-grade market study evaluates <strong>Incomplete PA</strong> for new residential construction feasibility. The analysis synthesizes data from 18+ government and commercial data sources including the U.S. Census Bureau, FRED, BLS, BEA, HUD, FHFA, Zillow, Redfin, RapidAPI Realtor.com, Parcl Labs, and SEC EDGAR filings, with AI-assisted synthesis via Anthropic Claude.</p><h3>Key Findings</h3><div class="kpi-grid four"><div class="kpi"><div class="value">5,000</div><div class="label">Population</div></div><div class="kpi"><div class="value accent">—</div><div class="label">Median HH Income</div></div><div class="kpi"><div class="value green">—</div><div class="label">Monthly Absorption</div></div><div class="kpi"><div class="value blue">—</div><div class="label">Annual Demand Gap</div></div></div><h2 class="page-break"><span class="section-num">2.</span> Market Area</h2><p class="narrative">The market study covers <strong>Incomplete Township</strong>, a township-level market within Unknown County County, PA.</p><dl class="def-list"><dt>Target Area</dt><dd>Incomplete Township</dd><dt>Subdivision/Township</dt><dd>Incomplete township</dd><dt>County</dt><dd>Unknown County</dd><dt>State</dt><dd>PA</dd><dt>CBSA (Metro)</dt><dd>—</dd><dt>State FIPS</dt><dd>42</dd><dt>County FIPS</dt><dd>—</dd><dt>Subdivision FIPS</dt><dd>—</dd><dt>ZIP Codes</dt><dd>15000</dd><dt>Coordinates</dt><dd>40.5000, -79.8000</dd></dl><p class="narrative" style="font-size:8.5pt;color:#6B7280;"><em>Note on data scope:</em> Demographic and housing metrics are reported at the most granular geography available from each source. County-level series (permits, employment, price indices) are labeled as such; sub-county metrics are reported at the township/subdivision level when available.</p><h2 class="page-break"><span class="section-num">3.</span> Demographics</h2><p class="narrative">The demographic profile of Incomplete PA reveals a population base of 5,000 residents across 2,000 households.</p><div class="kpi-grid"><div class="kpi"><div class="value">5,000</div><div class="label">Population</div></div><div class="kpi"><div class="value">—</div><div class="label">5-Year Growth</div></div><div class="kpi"><div class="value accent">—</div><div class="label">Median HH Income</div></div><div class="kpi"><div class="value">2,000</div><div class="label">Households</div></div><div class="kpi"><div class="value">—</div><div class="label">Homeownership Rate</div></div><div class="kpi"><div class="value">—</div><div class="label">Unemployment Rate</div></div></div><table><tr><th>Indicator</th><th class="text-right">Value</th></tr><tr><td>Median Age</td><td class="text-right">—</td></tr><tr><td>Avg Household Size</td><td class="text-right">—</td></tr><tr><td>Per Capita Income</td><td class="text-right">—</td></tr><tr><td>MHI Growth (YoY)</td><td class="text-right">—</td></tr><tr><td>Poverty Rate</td><td class="text-right">—</td></tr><tr><td>Vacancy Rate</td><td class="text-right">—</td></tr><tr><td>Affordable Ceiling</td><td class="text-right">—</td></tr><tr><td>Commute Inflow</td><td class="text-right">—</td></tr><tr><td>Commute Outflow</td><td class="text-right">—</td></tr></table><div class="section"><h2>4. Housing Supply &amp; Inventory</h2><div class="kpi-grid four"><div class="kpi"><div class="value">—</div><div class="label">Total Units</div></div><div class="kpi"><div class="value accent">0.75</div><div class="label">Owner-Occ</div></div><div class="kpi"><div class="value blue">—</div><div class="label">Renter-Occ</div></div><div class="kpi"><div class="value red">—</div><div class="label">Vacancy</div></div></div></div><div class="section"><h2>5. Building Permits &amp; Construction Activity</h2><p class="narrative">No permit data available for this market.</p></div><div class="section"><h2>6. Competitive Landscape</h2><div class="kpi-grid four"><div class="kpi"><div class="value">—</div><div class="label">Active Listings</div></div><div class="kpi"><div class="value accent">$—</div><div class="label">Median List</div></div><div class="kpi"><div class="value blue">35</div><div class="label">Days on Market</div></div><div class="kpi"><div class="value green">3</div><div class="label">Active Builders</div></div></div><h3>Active Builders (Top 3)</h3><table><tr><th>Builder</th><th>Communities</th><th>Price Range</th><th>Avg Sqft</th><th>$/Sqft</th></tr><tr><td>Acme Builders</td><td>—</td><td>—</td><td>—</td><td>—</td></tr><tr><td>Beta Homes</td><td>—</td><td>—</td><td>—</td><td>—</td></tr><tr><td>Gamma Developments</td><td>—</td><td>—</td><td>—</td><td>—</td></tr></table></div><div class="section"><h2>7. Absorption Analysis</h2><div class="kpi-grid"><div class="kpi"><div class="value accent">—</div><div class="label">Sales / Mo</div></div><div class="kpi"><div class="value">—</div><div class="label">Annual Sales</div></div><div class="kpi"><div class="value blue">— mo</div><div class="label">Months Supply</div></div></div></div><div class="section"><h2>8. Pricing Strategy</h2></div><div class="section"><h2>9. Land Acquisition</h2><div class="kpi-grid four"><div class="kpi"><div class="value">$—</div><div class="label">$/Lot Target</div></div><div class="kpi"><div class="value accent">—</div><div class="label">% of Revenue</div></div><div class="kpi"><div class="value blue">$—</div><div class="label">Finished Lot</div></div><div class="kpi"><div class="value green">—</div><div class="label">Lots/Acre</div></div></div></div><div class="section"><h2>10. Pro Forma Financials</h2><div class="kpi-grid four"><div class="kpi"><div class="value accent">$—</div><div class="label">Revenue</div></div><div class="kpi"><div class="value">$—</div><div class="label">Gross Profit</div></div><div class="kpi"><div class="value green">—</div><div class="label">GP Margin</div></div><div class="kpi"><div class="value blue">—</div><div class="label">Net Margin</div></div></div><h3>Forbes Capretto Homes Margin Gate</h3><div class="narrative">Forbes Capretto underwrites to a <strong>25-31% gross margin</strong> band (lower end for entry-level, upper end for premium/luxury). This scenario: <strong style="color:#6B7280">—</strong> at —.</div><h3>SEC EDGAR Public Builder Benchmarks (latest 10-K)</h3><p class="narrative" style="font-size:8.5pt;color:#6B7280;">Source: SEC EDGAR companyfacts. Revenue / GP / ASP / cancellation rate extracted from most recent 10-K per builder. <strong>0 of 3 builders</strong> had 10-K data resolvable at render time; remaining rows render dashes honestly.</p><table><tr><th>Builder</th><th class="text-right">Revenue</th><th class="text-right">GP Margin</th><th class="text-right">Homes Delivered</th><th class="text-right">ASP</th><th class="text-right">Cancel Rate</th><th class="text-right">Filing</th></tr><tr><td>Acme Builders</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right" style="font-size:8.5pt;color:#6B7280;">—</td></tr><tr><td>Beta Homes</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right" style="font-size:8.5pt;color:#6B7280;">—</td></tr><tr><td>Gamma Developments</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right" style="font-size:8.5pt;color:#6B7280;">—</td></tr></table></div><div class="section"><h2>11. Regulatory Environment</h2></div><div class="section"><h2>12. Market Scorecard</h2><div class="score-summary" style="background:#FEE2E2;border-radius:8px;padding:20px;margin:16px 0;text-align:center;"><div style="font-size:36pt;font-weight:700;color:#EF4444;">0.0 / 10</div><div style="font-size:14pt;color:#EF4444;font-weight:600;margin-top:6px;">PASS</div></div></div><div class="section"><h2>13. SWOT Analysis</h2><div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:14px 0;"><div style="background:#ECFDF5;border-left:4px solid #10B981;padding:14px;border-radius:4px;"><h3 style="color:#10B981;margin-top:0;">Strengths</h3><ul style="margin:0;padding-left:18px;"></ul></div><div style="background:#FEF2F2;border-left:4px solid #EF4444;padding:14px;border-radius:4px;"><h3 style="color:#EF4444;margin-top:0;">Weaknesses</h3><ul style="margin:0;padding-left:18px;"></ul></div><div style="background:#EFF6FF;border-left:4px solid #3B82F6;padding:14px;border-radius:4px;"><h3 style="color:#3B82F6;margin-top:0;">Opportunities</h3><ul style="margin:0;padding-left:18px;"></ul></div><div style="background:#FFFBEB;border-left:4px solid #F59E0B;padding:14px;border-radius:4px;"><h3 style="color:#F59E0B;margin-top:0;">Threats</h3><ul style="margin:0;padding-left:18px;"></ul></div></div></div><div class="section"><h2>14. Data Sources &amp; Methodology</h2><p class="narrative">This market study was assembled from 18 authoritative data sources, combining government statistics, commercial listings, and AI-driven analysis.</p><table><tr><th>Source</th><th>Data Provided</th><th>Last Updated</th></tr><tr><td>U.S. Census Bureau ACS</td><td>5-Year American Community Survey — population, income, housing characteristics</td><td>Current</td></tr><tr><td>U.S. Census Bureau PEP</td><td>Population Estimates Program — annual population estimates</td><td>Current</td></tr><tr><td>U.S. Census Bureau LODES</td><td>LEHD Origin-Destination Employment Statistics — commute flows</td><td>Current</td></tr><tr><td>Census CBP</td><td>County Business Patterns — employment by NAICS sector</td><td>Current</td></tr><tr><td>FRED / BLS</td><td>Federal Reserve Economic Data — unemployment rate, LAUS series</td><td>Current</td></tr><tr><td>BEA</td><td>Bureau of Economic Analysis — per capita personal income</td><td>Current</td></tr><tr><td>Census BPS</td><td>Building Permits Survey — residential permits by unit type</td><td>Current</td></tr><tr><td>HUD FMR</td><td>Fair Market Rents — rental rates by bedroom count</td><td>Current</td></tr><tr><td>FHFA HPI</td><td>Federal Housing Finance Agency — House Price Index</td><td>Current</td></tr><tr><td>Zillow ZHVI</td><td>Zillow Home Value Index — monthly home value trend</td><td>Current</td></tr><tr><td>Redfin</td><td>Redfin data center — DOM, sale-to-list, months supply</td><td>Current</td></tr><tr><td>RapidAPI Realtor.com</td><td>New construction filter — active communities</td><td>Current</td></tr><tr><td>NewHomeSource</td><td>Community listings &amp; pricing</td><td>Current</td></tr><tr><td>Parcl Labs</td><td>Price-per-square-foot and inventory metrics</td><td>Current</td></tr><tr><td>SEC EDGAR</td><td>Public builder 10-K filings — gross margins, ASP, cancellation rates</td><td>Current</td></tr><tr><td>BLS PPI</td><td>Producer Price Index — construction cost inflation</td><td>Current</td></tr><tr><td>Anthropic Claude API</td><td>claude-sonnet-4-6 — structured market analysis, scoring, SWOT</td><td>Current</td></tr><tr><td>Infinity Markets</td><td>Report generated 2026-04-22</td><td>Current</td></tr></table><h3>Methodology</h3><p class="narrative">Demographic data is sourced from the U.S. Census Bureau (ACS 5-year estimates) and Bureau of Labor Statistics. Housing inventory is pulled from Redfin, Zillow ZHVI, and MLS feeds via RapidAPI Realtor. Competitive intelligence combines NewHomeSource active listings with SEC EDGAR filings for public builders. Absorption, pricing, land, and pro forma analysis is synthesized using Claude Sonnet 4 against the aggregated dataset. The market scorecard applies a weighted 10-factor methodology calibrated to Forbes Capretto Homes underwriting criteria.</p><div class="footer-note" style="margin-top:24px;padding-top:12px;border-top:1px solid #E5E7EB;font-size:8pt;color:#6B7280;">Infinity Markets — Institutional Market Intelligence Platform. Report generated 4/22/2026, 5:00:00 PM.</div></div><div class="section"><h2>Appendix A: Data Quality Report</h2><p class="narrative">This appendix lists schema gaps detected during study assembly. It is emitted only when one or more required canonical fields are missing or unknown fields are present, so underwriters can see exactly where upstream data did not land before relying on derived figures.</p><p class="narrative" style="font-weight:600;color:#92400E;background:#FEF3C7;padding:10px 14px;border-left:4px solid #F59E0B;border-radius:4px;">Summary: 21 missing required, 4 unknown — geo.countyFips, demographics.mhi, housing.medianSalePrice, analysis.pricing.targetHomePrice, analysis.pricing.recommendedTier, +20 more</p><table><tr><th style="width:32%">Field</th><th style="width:24%">Issue</th><th>Detail</th></tr><tr style="background:#FFFBEB;"><td style="font-family:Menlo,monospace;font-size:9pt;">geo.countyFips</td><td><span style="display:inline-block;padding:2px 8px;background:#F59E0B;color:#fff;border-radius:10px;font-size:8.5pt;font-weight:600;">Missing Required</span></td><td style="font-size:9.5pt;color:#475569;">sources: census-geocoder|fallback-map</td></tr><tr style="background:#FFFBEB;"><td style="font-family:Menlo,monospace;font-size:9pt;">demographics.mhi</td><td><span style="display:inline-block;padding:2px 8px;background:#F59E0B;color:#fff;border-radius:10px;font-size:8.5pt;font-weight:600;">Missing Required</span></td><td style="font-size:9.5pt;color:#475569;">sources: acs</td></tr><tr style="background:#FFFBEB;"><td style="font-family:Menlo,monospace;font-size:9pt;">housing.medianSalePrice</td><td><span style="display:inline-block;padding:2px 8px;background:#F59E0B;color:#fff;border-radius:10px;font-size:8.5pt;font-weight:600;">Missing Required</span></td><td style="font-size:9.5pt;color:#475569;">sources: redfin|zillow</td></tr><tr style="background:#FFFBEB;"><td style="font-family:Menlo,monospace;font-size:9pt;">analysis.pricing.targetHomePrice</td><td><span style="display:inline-block;padding:2px 8px;background:#F59E0B;color:#fff;border-radius:10px;font-size:8.5pt;font-weight:600;">Missing Required</span></td><td style="font-size:9.5pt;color:#475569;">sources: derived</td></tr><tr style="background:#FFFBEB;"><td style="font-family:Menlo,monospace;font-size:9pt;">analysis.pricing.recommendedTier</td><td><span style="display:inline-block;padding:2px 8px;background:#F59E0B;color:#fff;border-radius:10px;font-size:8.5pt;font-weight:600;">Missing Required</span></td><td style="font-size:9.5pt;color:#475569;">sources: claude|derived</td></tr><tr style="background:#FFFBEB;"><td style="font-family:Menlo,monospace;font-size:9pt;">analysis.pricing.stratification</td><td><span sty